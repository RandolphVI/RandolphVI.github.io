---
---
<div id="scroll-buttons" class="fixed right-6 bottom-8 z-40 flex flex-col gap-1.5 opacity-0 transition-opacity duration-300 items-center">
  <button
    id="scroll-top"
    class="w-10 h-10 rounded-full bg-[var(--color-bg)] border border-[var(--color-border)] shadow-md flex items-center justify-center text-[var(--color-muted)] hover:text-[var(--color-heading)] hover:border-[var(--color-accent)] transition-colors cursor-pointer"
    aria-label="返回顶部"
    title="返回顶部"
  >
    ↑
  </button>

  <!-- Speed up -->
  <button
    id="speed-up"
    class="w-7 h-7 rounded-full bg-[var(--color-bg)] border border-[var(--color-border)] shadow-sm flex items-center justify-center text-[10px] text-[var(--color-muted)] hover:text-[var(--color-heading)] hover:border-[var(--color-accent)] transition-colors cursor-pointer"
    aria-label="加速"
    title="加速 +0.2x"
  >
    ▲
  </button>

  <!-- Auto reader -->
  <button
    id="auto-reader"
    class="w-10 h-10 rounded-full bg-[var(--color-bg)] border border-[var(--color-border)] shadow-md flex items-center justify-center text-[var(--color-muted)] hover:text-[var(--color-heading)] hover:border-[var(--color-accent)] transition-colors cursor-pointer"
    aria-label="自动阅读"
    title="自动阅读"
  >
    <span id="auto-reader-icon">▶</span>
  </button>

  <!-- Speed down -->
  <button
    id="speed-down"
    class="w-7 h-7 rounded-full bg-[var(--color-bg)] border border-[var(--color-border)] shadow-sm flex items-center justify-center text-[10px] text-[var(--color-muted)] hover:text-[var(--color-heading)] hover:border-[var(--color-accent)] transition-colors cursor-pointer"
    aria-label="减速"
    title="减速 -0.2x"
  >
    ▼
  </button>

  <button
    id="scroll-bottom"
    class="w-10 h-10 rounded-full bg-[var(--color-bg)] border border-[var(--color-border)] shadow-md flex items-center justify-center text-[var(--color-muted)] hover:text-[var(--color-heading)] hover:border-[var(--color-accent)] transition-colors cursor-pointer"
    aria-label="去底部"
    title="去底部"
  >
    ↓
  </button>
</div>

<!-- Speed indicator -->
<div id="speed-indicator" class="fixed right-[4.5rem] z-40 bg-[var(--color-bg)] border border-[var(--color-border)] shadow-md rounded-lg px-3 py-1.5 text-xs font-sans text-[var(--color-heading)] opacity-0 transition-opacity duration-200 pointer-events-none" style="bottom: calc(2rem + 5rem);">
  <span id="speed-text">0.6x</span>
</div>

<script>
  function initScrollButtons() {
    const container = document.getElementById('scroll-buttons');
    const topBtn = document.getElementById('scroll-top');
    const bottomBtn = document.getElementById('scroll-bottom');
    const autoBtn = document.getElementById('auto-reader');
    const autoIcon = document.getElementById('auto-reader-icon');
    const speedUpBtn = document.getElementById('speed-up');
    const speedDownBtn = document.getElementById('speed-down');
    const speedIndicator = document.getElementById('speed-indicator');
    const speedText = document.getElementById('speed-text');

    if (!container || !topBtn || !bottomBtn || !autoBtn || !autoIcon || !speedUpBtn || !speedDownBtn) return;

    let isAutoScrolling = false;
    let scrollSpeed = 0.6; // default speed
    let animationId: number | null = null;
    let speedTimeout: number | null = null;

    const MIN_SPEED = 0.2;
    const MAX_SPEED = 1.4;
    const STEP = 0.2;

    function updateVisibility() {
      const scrolled = window.scrollY > 300;
      container!.style.opacity = scrolled ? '1' : '0';
      container!.style.pointerEvents = scrolled ? 'auto' : 'none';
    }

    window.addEventListener('scroll', updateVisibility, { passive: true });
    updateVisibility();

    topBtn.addEventListener('click', () => {
      stopAutoScroll();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    bottomBtn.addEventListener('click', () => {
      stopAutoScroll();
      window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' });
    });

    // Auto scroll
    function autoScroll() {
      window.scrollBy(0, scrollSpeed);
      if (window.scrollY + window.innerHeight >= document.documentElement.scrollHeight) {
        stopAutoScroll();
        return;
      }
      animationId = requestAnimationFrame(autoScroll);
    }

    function startAutoScroll() {
      isAutoScrolling = true;
      autoIcon!.textContent = '⏸';
      autoBtn!.classList.add('!text-[var(--color-heading)]', '!border-[var(--color-accent)]');
      animationId = requestAnimationFrame(autoScroll);
      showSpeed();
    }

    function stopAutoScroll() {
      isAutoScrolling = false;
      autoIcon!.textContent = '▶';
      autoBtn!.classList.remove('!text-[var(--color-heading)]', '!border-[var(--color-accent)]');
      if (animationId) {
        cancelAnimationFrame(animationId);
        animationId = null;
      }
    }

    function showSpeed() {
      if (!speedIndicator || !speedText) return;
      speedText.textContent = scrollSpeed.toFixed(1) + 'x';
      speedIndicator.style.opacity = '1';
      if (speedTimeout) clearTimeout(speedTimeout);
      speedTimeout = window.setTimeout(() => {
        speedIndicator!.style.opacity = '0';
      }, 1500);
    }

    function adjustSpeed(delta: number) {
      scrollSpeed = Math.round((Math.min(MAX_SPEED, Math.max(MIN_SPEED, scrollSpeed + delta))) * 10) / 10;
      showSpeed();
    }

    autoBtn.addEventListener('click', () => {
      if (isAutoScrolling) {
        stopAutoScroll();
      } else {
        startAutoScroll();
      }
    });

    speedUpBtn.addEventListener('click', () => adjustSpeed(STEP));
    speedDownBtn.addEventListener('click', () => adjustSpeed(-STEP));

    // Scroll wheel on auto-reader button also adjusts speed
    autoBtn.addEventListener('wheel', (e) => {
      e.preventDefault();
      adjustSpeed(e.deltaY < 0 ? STEP : -STEP);
    }, { passive: false });

    // Stop auto-scroll on manual scroll
    window.addEventListener('wheel', (e) => {
      if (isAutoScrolling && e.target !== autoBtn && e.target !== speedUpBtn && e.target !== speedDownBtn) {
        stopAutoScroll();
      }
    }, { passive: true });

    window.addEventListener('keydown', (e) => {
      if (isAutoScrolling && ['Space', 'ArrowUp', 'ArrowDown', 'PageUp', 'PageDown'].includes(e.code)) {
        stopAutoScroll();
      }
    });
  }

  initScrollButtons();
  document.addEventListener('astro:page-load', initScrollButtons);
</script>
