<script>
  function initSidenotes() {
    const container = document.getElementById('sidenotes-container');
    const articleContent = document.querySelector('.article-content');
    if (!container || !articleContent) return;

    // Check if wide enough for sidenotes
    const isWide = window.innerWidth >= 1520;
    const footnoteSection = articleContent.querySelector('.footnotes');

    if (!isWide || !footnoteSection) return;

    // Extract footnote items
    const footnoteItems = footnoteSection.querySelectorAll('li');
    if (footnoteItems.length === 0) return;

    // Clear container
    container.innerHTML = '';
    container.style.position = 'relative';

    const GAP = 16; // minimum pixels between stacked sidenotes
    const placed: { el: HTMLElement; top: number; bottom: number }[] = [];

    footnoteItems.forEach((item, index) => {
      const id = item.id;
      const num = index + 1;

      // Find the reference in the article
      const ref = articleContent.querySelector(`a[href="#${id}"]`) ||
                  articleContent.querySelector(`sup a[href="#fn:${num}"]`) ||
                  articleContent.querySelector(`a.footnote-ref[href*="${num}"]`);

      // Create sidenote element
      const sidenote = document.createElement('div');
      sidenote.innerHTML = `
        <div class="text-sm text-[var(--color-accent-dark)] mb-1.5 font-sans">${num}</div>
        <div class="text-[0.95rem] text-[var(--color-muted)] leading-relaxed border-l border-[var(--color-border-dark)] pl-3">
          ${item.innerHTML.replace(/<a[^>]*class="footnote-backref"[^>]*>.*?<\/a>/g, '')}
        </div>
      `;
      sidenote.style.position = 'absolute';
      sidenote.style.left = '0';
      sidenote.style.right = '0';
      container.appendChild(sidenote);

      // Compute desired top based on reference position
      let desiredTop = 0;
      if (ref) {
        const refRect = ref.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();
        desiredTop = refRect.top - containerRect.top + container.scrollTop;
      } else if (placed.length > 0) {
        desiredTop = placed[placed.length - 1].bottom + GAP;
      }

      // Push down if overlapping with previous placed sidenote
      if (placed.length > 0) {
        const last = placed[placed.length - 1];
        if (desiredTop < last.bottom + GAP) {
          desiredTop = last.bottom + GAP;
        }
      }

      sidenote.style.top = `${desiredTop}px`;

      // Measure height after placement (it's already in DOM)
      const height = sidenote.offsetHeight;
      placed.push({ el: sidenote, top: desiredTop, bottom: desiredTop + height });
    });

    // Hide the original footnotes section
    (footnoteSection as HTMLElement).style.display = 'none';
  }

  // Run after page load and on resize
  window.addEventListener('load', initSidenotes);
  window.addEventListener('resize', () => {
    const container = document.getElementById('sidenotes-container');
    if (container) container.innerHTML = '';
    const footnotes = document.querySelector('.article-content .footnotes');
    if (footnotes) (footnotes as HTMLElement).style.display = '';
    initSidenotes();
  });
</script>
