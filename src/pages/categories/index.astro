---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, getPublishedTech } from '../../utils/collections';

const posts = await getPublishedPosts();
const tech = await getPublishedTech();

// ===== tech：按 category 字段分组 =====
const byCat = {};
for (const a of tech) (byCat[a.data.category] ??= []).push(a);
const sortDesc = (arr) => arr.slice().sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
const catList = (name) => sortDesc(byCat[name] ?? []);

// 「AI」Tab 下的细分分类（按由浅入深的阅读顺序）
const aiCats = ['机器学习', '深度学习', '自然语言处理', '推荐系统', '计算机视觉', 'AI 评估'];
const aiCount = aiCats.reduce((s, c) => s + (byCat[c]?.length ?? 0), 0);

// 数据 / 评价 / 杂谈
const dataArticles = catList('数据分析');
const evalArticles = catList('评价');
const techEssays = catList('杂谈');

// 架构（工具 + 前端）
const toolArticles = byCat['工具'] ?? [];
const archSpider = sortDesc(toolArticles.filter(a => a.data.tags.includes('Web Scraping')));
const archDB = sortDesc(toolArticles.filter(a => a.data.tags.includes('MongoDB')));
const archFrontend = catList('前端');
const archOther = sortDesc(toolArticles.filter(a => !a.data.tags.includes('Web Scraping') && !a.data.tags.includes('MongoDB')));

// ===== 匯文（小说 / 随笔）=====
const huiwen = posts.filter(a => a.data.category === '匯文');
const novelZiNan = huiwen.filter(a => a.data.tags.includes('子囡'));
const novelMoonTraveler = huiwen.filter(a => a.data.tags.includes('月球旅客'));
const novelFu = huiwen.filter(a => a.data.tags.includes('芾系列'));
const huiwenEssayProse = huiwen.filter(a => a.data.tags.includes('随笔'));
const huiwenReading = huiwen.filter(a => a.data.tags.includes('读书'));
const huiwenEssay = huiwen.filter(a => a.data.tags.includes('杂谈'));
const hasNovels = novelZiNan.length + novelMoonTraveler.length + novelFu.length > 0;

const tabs = [
  { id: 'huiwen', label: '匯文', count: huiwen.length + techEssays.length },
  { id: 'ai', label: 'AI', count: aiCount },
  { id: 'arch', label: '架构', count: toolArticles.length + archFrontend.length },
  { id: 'eval', label: '评价', count: evalArticles.length },
  { id: 'data', label: '数据', count: dataArticles.length },
];
---

<BaseLayout title="分类" description="按分类浏览文章">
  <div class="art-page-wrap">
    <header class="art-masthead">
      <div class="art-eyebrow">
        <span>CATEGORIES</span>
        <span>{tabs.reduce((a, t) => a + t.count, 0)} 篇</span>
      </div>
      <h1>分 类</h1>
      <p class="art-sub">按主题与脉络</p>
      <div class="art-rule"></div>
    </header>

    <!-- Tab bar -->
    <div class="flex justify-center gap-1 mb-10 border-b border-[var(--color-border-light)] pb-0">
      {tabs.map((tab, i) => (
        <button
          class:list={[
            'cat-tab font-sans text-base tracking-wider px-6 py-3 transition-colors cursor-pointer border-b-2 -mb-px',
            i === 0
              ? 'text-[var(--color-heading)] border-[var(--color-accent)]'
              : 'text-[var(--color-muted)] border-transparent hover:text-[var(--color-heading)]',
          ]}
          data-tab={tab.id}
        >
          {tab.label}
          <span class="text-xs text-[var(--color-faint)] ml-1.5 font-sans">{tab.count}</span>
        </button>
      ))}
    </div>

    <!-- Tab panels -->
    <div class="relative">

      {/* ========== 匯文 ========== */}
      <div class="cat-panel" data-panel="huiwen">
        <div class="tree-root">
          {hasNovels && (
            <div class="tree-node">
              <div class="tree-node-label">小说</div>
              <div class="tree-sub-nodes">
                {novelZiNan.length > 0 && (
                  <div class="tree-sub-node">
                    <div class="tree-sub-label">子囡</div>
                    <ul class="tree-list">
                      {novelZiNan.map(a => (
                        <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
                {novelMoonTraveler.length > 0 && (
                  <div class="tree-sub-node">
                    <div class="tree-sub-label">月球旅客</div>
                    <ul class="tree-list">
                      {novelMoonTraveler.map(a => (
                        <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
                {novelFu.length > 0 && (
                  <div class="tree-sub-node">
                    <div class="tree-sub-label">芾</div>
                    <ul class="tree-list">
                      {novelFu.map(a => (
                        <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          )}
          {huiwenEssayProse.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">随笔</div>
              <ul class="tree-list">
                {huiwenEssayProse.map(a => (
                  <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {huiwenReading.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">读书</div>
              <ul class="tree-list">
                {huiwenReading.map(a => (
                  <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {(huiwenEssay.length > 0 || techEssays.length > 0) && (
            <div class="tree-node">
              <div class="tree-node-label">杂谈</div>
              <div class="tree-sub-nodes">
                {huiwenEssay.length > 0 && (
                  <div class="tree-sub-node">
                    <ul class="tree-list">
                      {huiwenEssay.map(a => (
                        <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
                {techEssays.length > 0 && (
                  <div class="tree-sub-node">
                    <div class="tree-sub-label">科技碎碎念</div>
                    <ul class="tree-list">
                      {techEssays.map(a => (
                        <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
              </ul>
            </div>
          )}
        </div>
      </div>

      {/* ========== AI ========== */}
      <div class="cat-panel hidden" data-panel="ai">
        <div class="tree-root">
          {aiCats.map(c => (byCat[c]?.length > 0) && (
            <div class="tree-node">
              <div class="tree-node-label">{c}</div>
              <ul class="tree-list">
                {catList(c).map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      {/* ========== 架构 ========== */}
      <div class="cat-panel hidden" data-panel="arch">
        <div class="tree-root">
          {archSpider.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">爬虫</div>
              <ul class="tree-list">
                {archSpider.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {archDB.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">后端</div>
              <div class="tree-sub-nodes">
                <div class="tree-sub-node">
                  <div class="tree-sub-label">数据库</div>
                  <ul class="tree-list">
                    {archDB.map(a => (
                      <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          )}
          {archFrontend.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">前端</div>
              <ul class="tree-list">
                {archFrontend.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {archOther.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">其他</div>
              <ul class="tree-list">
                {archOther.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>

      {/* ========== 评价 ========== */}
      <div class="cat-panel hidden" data-panel="eval">
        <div class="tree-root">
          <div class="tree-node">
            <div class="tree-node-label">概念笔记</div>
            <ul class="tree-list">
              {evalArticles.map(a => (
                <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      {/* ========== 数据 ========== */}
      <div class="cat-panel hidden" data-panel="data">
        <div class="tree-root">
          <div class="tree-node">
            <div class="tree-node-label">数据分析</div>
            <ul class="tree-list">
              {dataArticles.map(a => (
                <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  /* === Tab Styles === */
  .cat-tab {
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
  }

  /* === Tree Layout === */
  .tree-root {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    max-width: 48rem;
    margin: 0 auto;
  }

  .tree-node {
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-border-light);
    position: relative;
  }

  .tree-node::before {
    content: '';
    position: absolute;
    left: -2px;
    top: 0;
    width: 12px;
    height: 2px;
    background: var(--color-accent);
  }

  .tree-node-label {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-heading);
    padding: 0.25rem 0.9rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    display: inline-block;
    margin-bottom: 0.6rem;
    margin-left: 0.5rem;
  }

  /* Article list - clean bullet style */
  .tree-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .tree-list li {
    position: relative;
    padding-left: 1rem;
  }

  .tree-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .tree-link {
    font-size: 0.95rem;
    color: var(--color-text);
    transition: color 0.2s;
    border-bottom: none !important;
  }

  .tree-link:hover {
    color: var(--color-heading);
  }

  /* Sub-nodes (3rd level) */
  .tree-sub-nodes {
    margin-left: 1.2rem;
    padding-left: 1rem;
    border-left: 1px solid var(--color-border-light);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .tree-sub-node {
    position: relative;
  }

  .tree-sub-node::before {
    content: '';
    position: absolute;
    left: -1rem;
    top: 0.65rem;
    width: 0.8rem;
    height: 1px;
    background: var(--color-border-light);
  }

  .tree-sub-label {
    font-size: 0.9rem;
    color: var(--color-accent-dark);
    font-family: 'Josefin Sans', sans-serif;
    margin-bottom: 0.4rem;
  }

  /* Panel animation */
  .cat-panel {
    animation: panelIn 0.25s ease-out;
  }

  @keyframes panelIn {
    from { opacity: 0; transform: translateX(12px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>

<script>
  function initCategoryTabs() {
    const tabs = document.querySelectorAll('.cat-tab');
    const panels = document.querySelectorAll('.cat-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-tab');

        // Update tab styles
        tabs.forEach(t => {
          t.classList.remove('text-[var(--color-heading)]', 'border-[var(--color-accent)]');
          t.classList.add('text-[var(--color-muted)]', 'border-transparent');
        });
        tab.classList.remove('text-[var(--color-muted)]', 'border-transparent');
        tab.classList.add('text-[var(--color-heading)]', 'border-[var(--color-accent)]');

        // Show/hide panels
        panels.forEach(p => {
          if (p.getAttribute('data-panel') === targetId) {
            p.classList.remove('hidden');
            // Re-trigger animation
            p.style.animation = 'none';
            p.offsetHeight; // force reflow
            p.style.animation = '';
          } else {
            p.classList.add('hidden');
          }
        });
      });
    });
  }

  initCategoryTabs();
  document.addEventListener('astro:page-load', initCategoryTabs);
</script>
