---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, getPublishedTech } from '../../utils/collections';

const posts = await getPublishedPosts();
const tech = await getPublishedTech();
const aiArticles = tech.filter(a => a.data.category === 'AI');

// --- AI: 深度学习 ---
const dlKeywords = ['Dropout', 'CNN', 'LSTM', 'RNN', 'RCNN', 'Word Representation', 'Word Embedding'];
const aiDeepLearning = aiArticles.filter(a =>
  dlKeywords.some(k => a.data.title.includes(k)) && !a.data.tags.includes('Books')
);

// --- AI: 理论学习 ---
const theoryKeywords = ['Cross Entropy'];
const aiTheory = aiArticles.filter(a =>
  theoryKeywords.some(k => a.data.title.includes(k))
);

// --- AI: 机器学习 ---
const mlKeywords = ['Factorization', 'Imbalanced', 'JPEG'];
const aiML = aiArticles.filter(a =>
  mlKeywords.some(k => a.data.title.includes(k)) && !a.data.tags.includes('Books')
);

// --- AI: 读书笔记 ---
const aiBooks = aiArticles.filter(a => a.data.tags.includes('Books'));
const mlBooks = aiBooks.filter(a => a.data.title.includes('Machine Learning'));
const nlpBooks = aiBooks.filter(a => a.data.title.includes('NLP'));
const pciBooks = aiBooks.filter(a => a.data.title.includes('Programming Collective'));
const otherBooks = aiBooks.filter(a =>
  !mlBooks.includes(a) && !nlpBooks.includes(a) && !pciBooks.includes(a)
);

// --- AI: 其他 (exclude 科技碎碎念 which goes to 杂谈, and Khan Academy which goes to 数据) ---
const aiOther = aiArticles.filter(a =>
  !aiDeepLearning.includes(a) && !aiTheory.includes(a) && !aiML.includes(a) && !aiBooks.includes(a)
  && !a.data.title.includes('科技碎碎念') && !a.data.title.includes('Khan Academy')
);

// --- 数据 ---
const dataArticles = tech.filter(a => a.data.title.includes('Khan Academy'));

// --- 杂谈 (tech) ---
const techEssays = tech.filter(a => a.data.title.includes('科技碎碎念'));

// --- 架构 ---
const archArticles = tech.filter(a => a.data.category === '工具' || a.data.category === '前端');
const archSpider = archArticles.filter(a => a.data.tags.includes('Web Scraping'));
const archDB = archArticles.filter(a => a.data.tags.includes('MongoDB'));
const archFrontend = tech.filter(a => a.data.category === '前端');
const archOther = archArticles.filter(a =>
  !archSpider.includes(a) && !archDB.includes(a) && !archFrontend.includes(a)
);

// --- 匯文 ---
const huiwen = posts.filter(a => a.data.category === '匯文');
const huiwenCreation = huiwen.filter(a => a.data.tags.includes('创作'));
const huiwenReading = huiwen.filter(a => a.data.tags.includes('读书'));
const huiwenEssay = huiwen.filter(a => a.data.tags.includes('杂谈'));
const huiwenClassic = huiwen.filter(a =>
  a.data.tags.includes('匯文') && !a.data.tags.includes('创作') && !a.data.tags.includes('读书') && !a.data.tags.includes('杂谈')
);

const aiTotal = aiDeepLearning.length + aiTheory.length + aiML.length + aiBooks.length + aiOther.length;
const archTotal = archArticles.length + archFrontend.length;
const dataTotal = dataArticles.length;
const huiwenTotal = huiwen.length + techEssays.length;
---

<BaseLayout title="分类" description="按分类浏览文章">
  <div class="max-w-5xl mx-auto px-6 lg:px-10 py-16">
    <div class="text-center mb-12">
      <div class="font-sans text-sm tracking-[4px] text-[var(--color-accent-dark)] mb-3">CATEGORIES</div>
      <h1 class="text-3xl tracking-[3px]">分类</h1>
      <div class="w-8 h-px bg-[var(--color-accent)] mx-auto mt-4"></div>
    </div>

    <div class="space-y-10">

      {/* ========== AI ========== */}
      <div class="tree-branch">
        <div class="tree-l1">
          <a href="/categories/AI/" class="tree-label-l1 border-none">AI</a>
          <span class="tree-count">{aiTotal}</span>
        </div>
        <div class="tree-children">

          {/* 深度学习 */}
          {aiDeepLearning.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">深度学习</span></div>
              <div class="tree-leaves">
                {aiDeepLearning.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}

          {/* 理论学习 */}
          {aiTheory.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">理论学习</span></div>
              <div class="tree-leaves">
                {aiTheory.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}

          {/* 机器学习 */}
          {aiML.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">机器学习</span></div>
              <div class="tree-leaves">
                {aiML.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}

          {/* 读书笔记 */}
          {aiBooks.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">读书笔记</span></div>
              <div class="tree-leaves">
                {mlBooks.length > 0 && (
                  <div class="tree-l3-group">
                    <span class="tree-label-l3">Machine Learning（周志华）</span>
                    <div class="tree-articles">
                      {mlBooks.map(a => (
                        <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                      ))}
                    </div>
                  </div>
                )}
                {nlpBooks.length > 0 && (
                  <div class="tree-l3-group">
                    <span class="tree-label-l3">NLP with Python</span>
                    <div class="tree-articles">
                      {nlpBooks.map(a => (
                        <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                      ))}
                    </div>
                  </div>
                )}
                {pciBooks.length > 0 && (
                  <div class="tree-l3-group">
                    <span class="tree-label-l3">Programming Collective Intelligence</span>
                    <div class="tree-articles">
                      {pciBooks.map(a => (
                        <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                      ))}
                    </div>
                  </div>
                )}
                {otherBooks.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}

          {/* 其他 */}
          {aiOther.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">其他</span></div>
              <div class="tree-leaves">
                {aiOther.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      {/* ========== 架构 ========== */}
      <div class="tree-branch">
        <div class="tree-l1">
          <span class="tree-label-l1">架构</span>
          <span class="tree-count">{archTotal}</span>
        </div>
        <div class="tree-children">

          {/* 爬虫 */}
          {archSpider.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">爬虫</span></div>
              <div class="tree-leaves">
                {archSpider.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}

          {/* 后端 - 数据库 */}
          {archDB.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">后端</span></div>
              <div class="tree-leaves">
                <div class="tree-l3-group">
                  <span class="tree-label-l3">数据库</span>
                  <div class="tree-articles">
                    {archDB.map(a => (
                      <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* 前端 */}
          {archFrontend.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">前端</span></div>
              <div class="tree-leaves">
                {archFrontend.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}

          {/* 其他 */}
          {archOther.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">其他</span></div>
              <div class="tree-leaves">
                {archOther.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      {/* ========== 数据 ========== */}
      {dataArticles.length > 0 && (
        <div class="tree-branch">
          <div class="tree-l1">
            <span class="tree-label-l1">数据</span>
            <span class="tree-count">{dataTotal}</span>
          </div>
          <div class="tree-children">
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">网站</span></div>
              <div class="tree-leaves">
                {dataArticles.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          </div>
        </div>
      )}

      {/* ========== 匯文 ========== */}
      <div class="tree-branch">
        <div class="tree-l1">
          <a href="/categories/匯文/" class="tree-label-l1 border-none">匯文</a>
          <span class="tree-count">{huiwenTotal}</span>
        </div>
        <div class="tree-children">
          {huiwenCreation.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">创作</span></div>
              <div class="tree-leaves">
                {huiwenCreation.map(a => (
                  <a href={`/posts/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}
          {huiwenReading.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">读书</span></div>
              <div class="tree-leaves">
                {huiwenReading.map(a => (
                  <a href={`/posts/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}
          {(huiwenEssay.length > 0 || techEssays.length > 0) && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">杂谈</span></div>
              <div class="tree-leaves">
                {huiwenEssay.map(a => (
                  <a href={`/posts/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
                {techEssays.map(a => (
                  <a href={`/tech/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}
          {huiwenClassic.length > 0 && (
            <div class="tree-branch-inner">
              <div class="tree-l2"><span class="tree-label-l2">匯文</span></div>
              <div class="tree-leaves">
                {huiwenClassic.map(a => (
                  <a href={`/posts/${a.id}/`} class="tree-article border-none">{a.data.title}</a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .tree-branch {
    position: relative;
  }

  .tree-l1 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .tree-label-l1 {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-heading);
    letter-spacing: 2px;
    padding: 0.4rem 1.2rem;
    border: 2px solid var(--color-accent) !important;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .tree-label-l1:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .tree-count {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.85rem;
    color: var(--color-faint);
  }

  .tree-children {
    margin-left: 2rem;
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-border-light);
  }

  .tree-branch-inner {
    position: relative;
    margin: 0.75rem 0;
  }

  .tree-branch-inner::before {
    content: '';
    position: absolute;
    left: -1.5rem;
    top: 0.85rem;
    width: 1.2rem;
    height: 2px;
    background: var(--color-border-light);
  }

  .tree-l2 {
    margin-bottom: 0.4rem;
  }

  .tree-label-l2 {
    font-size: 1.05rem;
    color: var(--color-heading);
    font-weight: 500;
    padding: 0.2rem 0.8rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    display: inline-block;
  }

  .tree-leaves {
    margin-left: 1.5rem;
    padding-left: 1rem;
    border-left: 1px solid var(--color-border-light);
  }

  .tree-l3-group {
    margin: 0.5rem 0;
    position: relative;
  }

  .tree-l3-group::before {
    content: '';
    position: absolute;
    left: -1rem;
    top: 0.7rem;
    width: 0.8rem;
    height: 1px;
    background: var(--color-border-light);
  }

  .tree-label-l3 {
    font-size: 0.9rem;
    color: var(--color-accent-dark);
    font-family: 'Josefin Sans', sans-serif;
    margin-bottom: 0.3rem;
    display: block;
  }

  .tree-articles {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-left: 0.5rem;
  }

  .tree-article {
    position: relative;
    font-size: 0.9rem;
    color: var(--color-text);
    padding: 0.15rem 0 0.15rem 1rem;
    transition: color 0.2s;
    border-bottom: none !important;
  }

  .tree-article::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  .tree-article:hover {
    color: var(--color-heading);
  }
</style>
