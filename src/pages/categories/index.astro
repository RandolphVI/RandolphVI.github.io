---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, getPublishedTech } from '../../utils/collections';

const posts = await getPublishedPosts();
const tech = await getPublishedTech();
const aiArticles = tech.filter(a => a.data.category === 'AI');

// --- AI: 深度学习 ---
const dlKeywords = ['Dropout', 'CNN', 'LSTM', 'RNN', 'RCNN', 'Word Representation', 'Word Embedding'];
const aiDeepLearning = aiArticles.filter(a =>
  dlKeywords.some(k => a.data.title.includes(k)) && !a.data.tags.includes('Books')
);

// --- AI: 理论学习 ---
const aiTheory = aiArticles.filter(a => a.data.title.includes('Cross Entropy'));

// --- AI: 机器学习 ---
const mlKeywords = ['Factorization', 'Imbalanced', 'JPEG'];
const aiML = aiArticles.filter(a =>
  mlKeywords.some(k => a.data.title.includes(k)) && !a.data.tags.includes('Books')
);

// --- AI: 读书笔记 ---
const aiBooks = aiArticles.filter(a => a.data.tags.includes('Books'));
const mlBooks = aiBooks.filter(a => a.data.title.includes('Machine Learning'));
const nlpBooks = aiBooks.filter(a => a.data.title.includes('NLP'));
const pciBooks = aiBooks.filter(a => a.data.title.includes('Programming Collective'));
const otherBooks = aiBooks.filter(a =>
  !mlBooks.includes(a) && !nlpBooks.includes(a) && !pciBooks.includes(a)
);

// --- AI: 其他 ---
const aiOther = aiArticles.filter(a =>
  !aiDeepLearning.includes(a) && !aiTheory.includes(a) && !aiML.includes(a) && !aiBooks.includes(a)
  && !a.data.title.includes('科技碎碎念') && !a.data.title.includes('Khan Academy')
);

// --- 数据 ---
const dataArticles = tech.filter(a => a.data.title.includes('Khan Academy'));

// --- 杂谈 (tech) ---
const techEssays = tech.filter(a => a.data.title.includes('科技碎碎念'));

// --- 架构 ---
const archArticles = tech.filter(a => a.data.category === '工具' || a.data.category === '前端');
const archSpider = archArticles.filter(a => a.data.tags.includes('Web Scraping'));
const archDB = archArticles.filter(a => a.data.tags.includes('MongoDB'));
const archFrontend = tech.filter(a => a.data.category === '前端');
const archOther = archArticles.filter(a =>
  !archSpider.includes(a) && !archDB.includes(a) && !archFrontend.includes(a)
);

// --- 匯文 ---
const huiwen = posts.filter(a => a.data.category === '匯文');
const huiwenCreation = huiwen.filter(a => a.data.tags.includes('创作'));
const huiwenReading = huiwen.filter(a => a.data.tags.includes('读书'));
const huiwenEssay = huiwen.filter(a => a.data.tags.includes('杂谈'));
// huiwenClassic removed — 我与地坛 and 水之湄 now tagged as 创作

const tabs = [
  { id: 'huiwen', label: '匯文', count: huiwen.length + techEssays.length },
  { id: 'ai', label: 'AI', count: aiArticles.length - techEssays.length - dataArticles.length },
  { id: 'arch', label: '架构', count: archArticles.length + archFrontend.length },
  { id: 'data', label: '数据', count: dataArticles.length },
];
---

<BaseLayout title="分类" description="按分类浏览文章">
  <div class="max-w-5xl mx-auto px-6 lg:px-10 py-16">
    <div class="text-center mb-10">
      <div class="font-sans text-sm tracking-[4px] text-[var(--color-accent-dark)] mb-3">CATEGORIES</div>
      <h1 class="text-3xl tracking-[3px]">分类</h1>
      <div class="w-8 h-px bg-[var(--color-accent)] mx-auto mt-4"></div>
    </div>

    <!-- Tab bar -->
    <div class="flex justify-center gap-1 mb-10 border-b border-[var(--color-border-light)] pb-0">
      {tabs.map((tab, i) => (
        <button
          class:list={[
            'cat-tab font-sans text-base tracking-wider px-6 py-3 transition-colors cursor-pointer border-b-2 -mb-px',
            i === 0
              ? 'text-[var(--color-heading)] border-[var(--color-accent)]'
              : 'text-[var(--color-muted)] border-transparent hover:text-[var(--color-heading)]',
          ]}
          data-tab={tab.id}
        >
          {tab.label}
          <span class="text-xs text-[var(--color-faint)] ml-1.5 font-sans">{tab.count}</span>
        </button>
      ))}
    </div>

    <!-- Tab panels -->
    <div class="relative">

      {/* ========== 匯文 ========== */}
      <div class="cat-panel" data-panel="huiwen">
        <div class="tree-root">
          {huiwenCreation.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">创作</div>
              <ul class="tree-list">
                {huiwenCreation.map(a => (
                  <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {huiwenReading.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">读书</div>
              <ul class="tree-list">
                {huiwenReading.map(a => (
                  <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {(huiwenEssay.length > 0 || techEssays.length > 0) && (
            <div class="tree-node">
              <div class="tree-node-label">杂谈</div>
              <ul class="tree-list">
                {huiwenEssay.map(a => (
                  <li><a href={`/posts/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
                {techEssays.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>

      {/* ========== AI ========== */}
      <div class="cat-panel hidden" data-panel="ai">
        <div class="tree-root">
          {aiDeepLearning.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">深度学习</div>
              <ul class="tree-list">
                {aiDeepLearning.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {aiTheory.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">理论学习</div>
              <ul class="tree-list">
                {aiTheory.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {aiML.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">机器学习</div>
              <ul class="tree-list">
                {aiML.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {aiBooks.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">读书笔记</div>
              <div class="tree-sub-nodes">
                {mlBooks.length > 0 && (
                  <div class="tree-sub-node">
                    <div class="tree-sub-label">Machine Learning（周志华）</div>
                    <ul class="tree-list">
                      {mlBooks.map(a => (
                        <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
                {nlpBooks.length > 0 && (
                  <div class="tree-sub-node">
                    <div class="tree-sub-label">NLP with Python</div>
                    <ul class="tree-list">
                      {nlpBooks.map(a => (
                        <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
                {pciBooks.length > 0 && (
                  <div class="tree-sub-node">
                    <div class="tree-sub-label">Programming Collective Intelligence</div>
                    <ul class="tree-list">
                      {pciBooks.map(a => (
                        <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          )}
          {aiOther.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">其他</div>
              <ul class="tree-list">
                {aiOther.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>

      {/* ========== 架构 ========== */}
      <div class="cat-panel hidden" data-panel="arch">
        <div class="tree-root">
          {archSpider.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">爬虫</div>
              <ul class="tree-list">
                {archSpider.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {archDB.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">后端</div>
              <div class="tree-sub-nodes">
                <div class="tree-sub-node">
                  <div class="tree-sub-label">数据库</div>
                  <ul class="tree-list">
                    {archDB.map(a => (
                      <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          )}
          {archFrontend.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">前端</div>
              <ul class="tree-list">
                {archFrontend.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          {archOther.length > 0 && (
            <div class="tree-node">
              <div class="tree-node-label">其他</div>
              <ul class="tree-list">
                {archOther.map(a => (
                  <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>

      {/* ========== 数据 ========== */}
      <div class="cat-panel hidden" data-panel="data">
        <div class="tree-root">
          <div class="tree-node">
            <div class="tree-node-label">网站</div>
            <ul class="tree-list">
              {dataArticles.map(a => (
                <li><a href={`/tech/${a.id}/`} class="tree-link border-none">{a.data.title}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  /* === Tab Styles === */
  .cat-tab {
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
  }

  /* === Tree Layout === */
  .tree-root {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    max-width: 48rem;
    margin: 0 auto;
  }

  .tree-node {
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-border-light);
    position: relative;
  }

  .tree-node::before {
    content: '';
    position: absolute;
    left: -2px;
    top: 0;
    width: 12px;
    height: 2px;
    background: var(--color-accent);
  }

  .tree-node-label {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-heading);
    padding: 0.25rem 0.9rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    display: inline-block;
    margin-bottom: 0.6rem;
    margin-left: 0.5rem;
  }

  /* Article list - clean bullet style */
  .tree-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .tree-list li {
    position: relative;
    padding-left: 1rem;
  }

  .tree-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .tree-link {
    font-size: 0.95rem;
    color: var(--color-text);
    transition: color 0.2s;
    border-bottom: none !important;
  }

  .tree-link:hover {
    color: var(--color-heading);
  }

  /* Sub-nodes (3rd level) */
  .tree-sub-nodes {
    margin-left: 1.2rem;
    padding-left: 1rem;
    border-left: 1px solid var(--color-border-light);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .tree-sub-node {
    position: relative;
  }

  .tree-sub-node::before {
    content: '';
    position: absolute;
    left: -1rem;
    top: 0.65rem;
    width: 0.8rem;
    height: 1px;
    background: var(--color-border-light);
  }

  .tree-sub-label {
    font-size: 0.9rem;
    color: var(--color-accent-dark);
    font-family: 'Josefin Sans', sans-serif;
    margin-bottom: 0.4rem;
  }

  /* Panel animation */
  .cat-panel {
    animation: panelIn 0.25s ease-out;
  }

  @keyframes panelIn {
    from { opacity: 0; transform: translateX(12px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>

<script>
  function initCategoryTabs() {
    const tabs = document.querySelectorAll('.cat-tab');
    const panels = document.querySelectorAll('.cat-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-tab');

        // Update tab styles
        tabs.forEach(t => {
          t.classList.remove('text-[var(--color-heading)]', 'border-[var(--color-accent)]');
          t.classList.add('text-[var(--color-muted)]', 'border-transparent');
        });
        tab.classList.remove('text-[var(--color-muted)]', 'border-transparent');
        tab.classList.add('text-[var(--color-heading)]', 'border-[var(--color-accent)]');

        // Show/hide panels
        panels.forEach(p => {
          if (p.getAttribute('data-panel') === targetId) {
            p.classList.remove('hidden');
            // Re-trigger animation
            p.style.animation = 'none';
            p.offsetHeight; // force reflow
            p.style.animation = '';
          } else {
            p.classList.add('hidden');
          }
        });
      });
    });
  }

  initCategoryTabs();
  document.addEventListener('astro:page-load', initCategoryTabs);
</script>
