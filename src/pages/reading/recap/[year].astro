    @keyframes dpFade {
      from { opacity: 0; transform: translateY(-6px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .dp-head {
      font-family: 'KingHwa_OldSong', serif;
      font-size: 0.95rem;
      letter-spacing: 4px;
      color: var(--color-heading);
      margin-bottom: 1rem;
