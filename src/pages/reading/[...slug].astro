---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const books = await getCollection('reading');
  return books.map((book) => ({
    params: { slug: book.id },
    props: { book },
  }));
}

const { book } = Astro.props;
const { Content } = await render(book);
const d = book.data;

function fmt(date?: Date) {
  if (!date) return '';
  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
}

const metaItems: Array<[string, string]> = [];
if (d.publisher) metaItems.push(['出版社', d.publisher]);
if (d.pubDate) metaItems.push(['出版年', d.pubDate]);
if (d.isbn) metaItems.push(['ISBN', d.isbn]);
if (d.readingTime) metaItems.push(['阅读时长', d.readingTime]);
if (d.startDate) metaItems.push(['开始', fmt(d.startDate)]);
if (d.finishedDate) metaItems.push(['读毕', fmt(d.finishedDate)]);
if (!d.finishedDate && d.progress) metaItems.push(['进度', d.progress]);
---

<BaseLayout title={d.title} description={d.summary || `${d.author}的作品`} image={d.cover}>
  <article class="book-page">

    <!-- ╔══════════════════════════════════════╗ -->
    <!-- ║   EDITORIAL HEADER (full width)        ║ -->
    <!-- ╚══════════════════════════════════════╝ -->
    <header class="book-head">
      <a href="/reading/" class="book-crumb">← 回 到 书 架</a>
      <div class="book-eyebrow">
        <span>{d.bookCategory ? d.bookCategory.split('-')[0] : '书'}</span>
        <span>READING&nbsp;NOTE</span>
      </div>
      <h1 class="book-title">{d.title}</h1>
      <p class="book-author">{d.author}</p>
      <div class="book-rule"></div>
      {d.summary && (
        <p class="book-summary">{d.summary}</p>
      )}
    </header>

    <!-- ╔══════════════════════════════════════╗ -->
    <!-- ║   3-COL GRID: cover | meta | body       ║ -->
    <!-- ╚══════════════════════════════════════╝ -->
    <div class="book-body-grid">

      <aside class="book-side">
        <div class="book-cover-wrap">
          {d.cover ? (
            <img src={d.cover} alt={d.title} class="book-cover" />
          ) : (
            <div class="book-cover book-cover-placeholder">书影</div>
          )}
        </div>

        <dl class="book-meta">
          {metaItems.map(([k, v]) => (
            <>
              <dt>{k}</dt>
              <dd>{v}</dd>
            </>
          ))}
        </dl>
      </aside>

      <main class="book-content">
        <Content />
      </main>

    </div>
  </article>

  <style is:global>
    .book-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }
    @media (max-width: 768px) {
      .book-page { padding: 2rem 1.5rem 4rem; }
    }

    /* ============ HEADER ============ */
    .book-head {
      max-width: 820px;
      margin: 0 auto 4rem;
      text-align: center;
    }
    .book-crumb {
      display: inline-block;
      font-family: 'KingHwa_OldSong', serif;
      font-size: 0.78rem;
      letter-spacing: 4px;
      color: var(--color-faint);
      border: none !important;
      margin-bottom: 2.5rem;
      transition: color 0.2s;
    }
    .book-crumb:hover { color: var(--color-heading); }

    .book-eyebrow {
      display: flex;
      justify-content: center;
      align-items: baseline;
      gap: 1.5rem;
      font-family: 'Josefin Sans', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 4px;
      color: var(--color-accent-dark);
      text-transform: uppercase;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--color-border-light);
      margin-bottom: 1.5rem;
    }
    .book-eyebrow > span:first-child {
      font-family: 'KingHwa_OldSong', serif;
      font-size: 0.8rem;
      letter-spacing: 4px;
      text-transform: none;
      color: var(--color-muted);
    }

    .book-title {
      font-family: 'KingHwa_OldSong', 'Noto Serif SC', serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      line-height: 1.25;
      letter-spacing: 0.06em;
      color: var(--color-heading);
      font-weight: 400;
      margin: 0 0 1rem;
    }
    .book-author {
      font-family: 'KingHwa_OldSong', serif;
      font-size: 0.95rem;
      color: var(--color-muted);
      letter-spacing: 0.2em;
      margin: 0 0 1.5rem;
    }
    .book-rule {
      width: 30px;
      height: 1px;
      background: var(--color-accent);
      margin: 0 auto 2rem;
    }
    .book-summary {
      font-family: 'KingHwa_OldSong', serif;
      font-size: 1rem;
      line-height: 1.95;
      color: var(--color-muted);
      max-width: 640px;
      margin: 0 auto;
      letter-spacing: 0.025em;
    }

    /* ============ BODY GRID ============ */
    .book-body-grid {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 4rem;
    }
    @media (max-width: 900px) {
      .book-body-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    }

    .book-side {
      position: sticky;
      top: 2rem;
      align-self: start;
    }
    @media (max-width: 900px) {
      .book-side { position: static; max-width: 280px; margin: 0 auto; }
    }

    .book-cover-wrap {
      margin-bottom: 1.6rem;
    }
    .book-cover {
      width: 100%;
      aspect-ratio: 2 / 3;
      object-fit: cover;
      display: block;
      box-shadow: 0 8px 32px rgba(0,0,0,0.14), 0 2px 6px rgba(0,0,0,0.08);
    }
    :root.dark .book-cover {
      box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 2px 6px rgba(0,0,0,0.3);
    }
    .book-cover-placeholder {
      background: var(--color-surface);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-muted);
      font-size: 0.95rem;
      letter-spacing: 6px;
      writing-mode: vertical-rl;
      border: 1px solid var(--color-border);
    }

    .book-meta {
      margin: 0;
      padding: 1.4rem 0 0;
      border-top: 1px solid var(--color-border-light);
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.7rem 1rem;
      font-family: 'Josefin Sans', sans-serif;
      font-size: 0.8rem;
    }
    .book-meta dt {
      font-family: 'KingHwa_OldSong', serif;
      font-size: 0.75rem;
      letter-spacing: 3px;
      color: var(--color-faint);
      white-space: nowrap;
    }
    .book-meta dd {
      margin: 0;
      color: var(--color-muted);
      letter-spacing: 0.5px;
      font-size: 0.78rem;
    }

    /* ============ CONTENT (highlights area) ============ */
    .book-content {
      min-width: 0;
      font-family: 'KingHwa_OldSong', 'Noto Serif SC', serif;
    }

    /* Chapter heading (## 第X章 ...) */
    .book-content h2 {
      font-family: 'KingHwa_OldSong', serif;
      font-size: 1.15rem;
      letter-spacing: 0.1em;
      color: var(--color-heading);
      margin: 3.5rem 0 2rem;
      padding-bottom: 0.6rem;
      position: relative;
      font-weight: 400;
    }
    .book-content h2:first-child { margin-top: 0; }
    .book-content h2::before {
      content: 'CHAPTER';
      display: block;
      font-family: 'Josefin Sans', sans-serif;
      font-size: 0.62rem;
      letter-spacing: 4px;
      color: var(--color-accent-dark);
      margin-bottom: 0.5rem;
      font-weight: 400;
    }
    .book-content h2::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 24px;
      height: 1px;
      background: var(--color-accent);
    }

    /* Highlights (blockquote) */
    .book-content blockquote {
      margin: 1.5rem 0;
      padding: 0 0 0 1.6rem;
      border: none;
      border-left: 1px solid var(--color-border-dark);
      font-style: normal;
      background: none;
    }
    .book-content blockquote p {
      font-family: 'KingHwa_OldSong', 'Noto Serif SC', serif;
      font-size: 1rem;
      line-height: 2;
      color: var(--color-text);
      letter-spacing: 0.025em;
      margin: 0 0 0.9rem;
    }
    .book-content blockquote p:last-child { margin-bottom: 0; }
    .book-content blockquote::before {
      content: none;
    }

    /* Body paragraphs (book reviews etc) */
    .book-content > p {
      font-family: 'KingHwa_OldSong', serif;
      font-size: 1rem;
      line-height: 2;
      color: var(--color-text);
      margin: 1.2rem 0;
    }

    /* Drop the dropcap from article.css that would otherwise apply */
    .book-content > h2 + p::first-letter,
    .book-content > h2 + blockquote::first-letter,
    .book-content > h2 + blockquote p::first-letter {
      float: none;
      font-size: inherit;
      line-height: inherit;
      margin: 0;
      padding: 0;
      color: inherit;
      background: none !important;
      border: none !important;
      text-shadow: none !important;
    }
  </style>
</BaseLayout>
