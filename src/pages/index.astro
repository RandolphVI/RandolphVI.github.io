---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getPublishedPosts } from '../utils/collections';
import { getVolumeLabel } from '../utils/season';

const allPosts = await getPublishedPosts();
const volumeLabel = getVolumeLabel(allPosts.length, new Date());

// Prepare cover candidates (all posts for random selection)
const coverCandidates = allPosts.map(p => ({
  id: p.id,
  title: p.data.title,
  category: p.data.category,
  description: p.data.description,
}));

// Recent posts for the list (latest 5)
const recentPosts = allPosts.slice(0, 5);
---

<BaseLayout title="首页" description="黃某人的个人博客 — 写小说，读闲书，偶尔研究机器学习">
  <script define:vars={{ coverCandidates }} is:inline>
    // Pick random post on each page load
    const pick = coverCandidates[Math.floor(Math.random() * coverCandidates.length)];
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('cover-title').textContent = pick.title;
      document.getElementById('cover-category').textContent = '随机推荐 · ' + pick.category;
      document.getElementById('cover-desc').textContent = pick.description;
      document.getElementById('cover-link').href = '/posts/' + pick.id + '/';
    });
  </script>

  <!-- Cover Section -->
  <div class="relative py-16 px-6 lg:px-10 text-center">
    <div class="absolute top-10 right-6 lg:right-10 text-[11px] text-[var(--color-accent)] tracking-[6px] font-serif hidden sm:block" style="writing-mode: vertical-rl;">
      痴
    </div>

    <div class="font-sans text-sm tracking-[6px] text-[var(--color-accent-dark)] mb-5">
      {volumeLabel}
    </div>
    <div class="w-10 h-px bg-[var(--color-accent)] mx-auto mb-6"></div>

    <div>
      <h2 id="cover-title" class="text-4xl text-[var(--color-heading)] tracking-[4px] mb-4">
        {coverCandidates[0]?.title}
      </h2>
      <div id="cover-category" class="font-sans text-base text-[var(--color-muted)] tracking-wider mb-6">
        随机推荐 · {coverCandidates[0]?.category}
      </div>
      <p id="cover-desc" class="max-w-2xl mx-auto text-lg text-[var(--color-muted)] leading-[2.2]">
        {coverCandidates[0]?.description}
      </p>
      <div class="mt-8">
        <a
          id="cover-link"
          href={`/posts/${coverCandidates[0]?.id}/`}
          class="inline-block font-sans text-sm text-[var(--color-accent-dark)] border border-[var(--color-border-dark)] px-6 py-2 tracking-[2px] hover:bg-[var(--color-accent)] hover:text-[var(--color-bg)] transition-colors"
        >
          阅读全文
        </a>
      </div>
    </div>
  </div>

  <!-- Gradient divider -->
  <div class="w-3/5 h-px mx-auto" style="background: linear-gradient(90deg, transparent, var(--color-border-dark), transparent);"></div>

  <!-- Recent Articles -->
  <div class="max-w-2xl mx-auto px-6 lg:px-10 py-10">
    <div class="font-sans text-sm tracking-[4px] text-[var(--color-accent-dark)] mb-6">
      近期文章
    </div>

    {recentPosts.map((post) => (
      <ArticleCard
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        href={`/posts/${post.id}/`}
      />
    ))}

    <div class="text-center mt-8">
      <a href="/archives/" class="font-sans text-[11px] text-[var(--color-accent-dark)] tracking-[2px] border-none hover:text-[var(--color-heading)]">
        查看全部 →
      </a>
    </div>
  </div>
</BaseLayout>
