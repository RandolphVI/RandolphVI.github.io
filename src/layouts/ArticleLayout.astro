---
import BaseLayout from './BaseLayout.astro';
import EndMark from '../components/EndMark.astro';
import { getReadingTime } from '../utils/reading-time';
import ReadingProgress from '../components/ReadingProgress.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Sidenotes from '../components/Sidenotes.astro';
import ScrollButtons from '../components/ScrollButtons.astro';
import '../styles/article.css';

interface Props {
  title: string;
  date: Date;
  category: string;
  tags: string[];
  description: string;
  rawContent: string;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: { title: string; href: string };
  nextPost?: { title: string; href: string };
}

const { title, date, category, tags, description, rawContent, headings, prevPost, nextPost } = Astro.props;

const { minutes, words } = getReadingTime(rawContent);
const dateStr = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
const showSidebar = true;
---

<BaseLayout title={title} description={description}>
  <ReadingProgress />
  <div class="max-w-[1400px] mx-auto px-4 lg:px-8 py-10">
    <div class="flex gap-0 lg:gap-10 justify-center">

      <!-- Left: Article Info + TOC (desktop only) -->
      {showSidebar && (
        <aside class="hidden xl:block w-52 flex-shrink-0 pt-20">
          <TableOfContents
            headings={headings}
            title={title}
            date={date}
            category={category}
            tags={tags}
            words={words}
            minutes={minutes}
          />
        </aside>
      )}

      <!-- Center: Article Content -->
      <article class="w-full max-w-[860px]">
        <!-- Article Header -->
        <div class="text-center mb-10 article-fade-in">
          <div class="font-sans text-xs tracking-[4px] text-[var(--color-accent-dark)] mb-4">
            {category}
          </div>
          <h1 class="text-3xl text-[var(--color-heading)] tracking-[3px] mb-4">
            {title}
          </h1>
          <div class="flex justify-center gap-4 font-sans text-xs text-[var(--color-faint)]">
            <span>{dateStr}</span>
            <span>·</span>
            <span>约 {words} 字</span>
            <span>·</span>
            <span>{minutes} 分钟</span>
          </div>
        </div>

        <div class="w-10 h-px bg-[var(--color-accent)] mx-auto mb-9"></div>

        <!-- Article Body -->
        <div class="article-content article-fade-in-delay">
          <slot />
        </div>

        <EndMark />

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 justify-center mt-6">
          {tags.map((tag) => (
            <a
              href={`/tags/${encodeURIComponent(tag)}/`}
              class="font-sans text-xs text-[var(--color-accent-dark)] border border-[var(--color-border-dark)] px-3 py-1 hover:bg-[var(--color-accent)] hover:text-[var(--color-bg)] transition-colors !border-b !border-[var(--color-border-dark)]"
              style="border-bottom: 1px solid var(--color-border-dark) !important;"
            >
              {tag}
            </a>
          ))}
        </div>

        <!-- Prev / Next Navigation -->
        {(prevPost || nextPost) && (
          <div class="mt-12 pt-6 border-t border-[var(--color-border)] flex justify-between">
            {prevPost ? (
              <a href={prevPost.href} class="border-none group">
                <div class="text-[var(--color-faint)] text-xs tracking-[2px] font-sans mb-1">← 上一篇</div>
                <div class="text-base text-[var(--color-muted)] group-hover:text-[var(--color-heading)] transition-colors">{prevPost.title}</div>
              </a>
            ) : <div />}
            {nextPost ? (
              <a href={nextPost.href} class="text-right border-none group">
                <div class="text-[var(--color-faint)] text-xs tracking-[2px] font-sans mb-1">下一篇 →</div>
                <div class="text-base text-[var(--color-muted)] group-hover:text-[var(--color-heading)] transition-colors">{nextPost.title}</div>
              </a>
            ) : <div />}
          </div>
        )}
      </article>

      <!-- Right: Sidenotes area (desktop only, populated in Task 8) -->
      <aside class="hidden xl:block w-72 flex-shrink-0 pt-20" id="sidenotes-container">
      </aside>

    </div>
  </div>
  <Sidenotes />
  <ScrollButtons />
</BaseLayout>
